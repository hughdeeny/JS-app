---
import Layout from '../layouts/Layout.astro';
import {
  WHATSAPP_URL,
  WHATSAPP_DISPLAY,
  images,
  trips,
  whyBook,
  galleryImages,
  faqs,
  socialLinks,
} from '../data/site';
---

<Layout>
  <!-- Hero -->
  <section id="home" class="hero">
    <div class="hero__bg">
      <picture>
        <source srcset={images.heroSurfEnhanced} type="image/webp" />
        <img src={images.heroSurfEnhancedJpg} alt="Surfer riding a powerful wave at Cloudbreak, Fiji" />
      </picture>
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content container">
      <p class="hero__eyebrow">Nabila Village, Fiji</p>
      <h1 class="hero__title">Bula Boys Surf Tours Fiji</h1>
      <p class="hero__subtitle">
        Local Fiji surf trips to Cloudbreak from Nabila Village, with lifeguards, snorkelling, fishing, and easy WhatsApp booking.
      </p>
      <div class="hero__actions">
        <a href={WHATSAPP_URL} class="btn btn--whatsapp" target="_blank" rel="noopener noreferrer">
          <svg class="whatsapp-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Book on WhatsApp
        </a>
        <a href="#trips" class="btn btn--outline">View Trips</a>
      </div>
      <a href={WHATSAPP_URL} class="hero__phone" target="_blank" rel="noopener noreferrer">
        WhatsApp {WHATSAPP_DISPLAY}
      </a>
    </div>
  </section>

  <!-- About -->
  <section class="section about">
    <div class="container about__grid">
      <div class="about__image-wrap">
        <img src={images.aboutBoat} alt="Smiling local Fijian surf guide and guest on a boat in Fiji" loading="lazy" />
      </div>
      <div class="about__text">
        <h2 class="section-title">Local Fiji Ocean Trips From Nabila Village</h2>
        <p class="about__copy">
          Bula Boys Surf Tours Fiji takes visitors from Nabila Village to Cloudbreak and nearby ocean spots for surf trips, snorkelling, and fishing. Our local team knows the water, the conditions, and the best way to help you enjoy a safe, relaxed, and memorable day in Fiji.
        </p>
      </div>
    </div>
  </section>

  <!-- Trips -->
  <section id="trips" class="section section--sand trips">
    <div class="container">
      <h2 class="section-title">Trips</h2>
      <p class="section-lead">Surf, snorkel, fish, or get local support on the water — all from Nabila Village.</p>
      <div class="trips__grid">
        {trips.map((trip) => (
          <a href={trip.href} class="trip-card">
            <div class="trip-card__image">
              <img src={trip.image} alt={trip.alt} loading="lazy" />
            </div>
            <div class="trip-card__body">
              <h3 class="trip-card__title">{trip.title}</h3>
              <p class="trip-card__copy">{trip.copy}</p>
              <span class="trip-card__link">Learn more →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why book -->
  <section class="section why">
    <div class="container">
      <h2 class="section-title">Why Book With Bula Boys</h2>
      <ul class="why__list">
        {whyBook.map((point) => (
          <li class="why__item">
            <span class="why__check" aria-hidden="true">✓</span>
            {point}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="section section--seafoam gallery">
    <div class="container">
      <h2 class="section-title">Gallery</h2>
      <p class="section-lead">Real days on the water — Cloudbreak waves, local boats, and Fiji island life.</p>
      <div class="gallery__grid">
        {galleryImages.map((item) => (
          <figure class={`gallery__item gallery__item--${item.size ?? 'medium'}`}>
            <img src={item.src} alt={item.alt} loading="lazy" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="section section--sand faq">
    <div class="container">
      <h2 class="section-title">FAQ</h2>
      <div class="faq__list">
        {faqs.map((item) => (
          <details class="faq__item">
            <summary class="faq__question">{item.question}</summary>
            <p class="faq__answer">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section id="contact" class="final-cta">
    <div class="final-cta__bg">
      <img src={images.sunsetBeach} alt="Tropical sunset at a Fiji beach" loading="lazy" />
      <div class="final-cta__overlay"></div>
    </div>
    <div class="container final-cta__content">
      <h2 class="final-cta__title">Ready for a Fiji Ocean Trip?</h2>
      <p class="final-cta__copy">
        Message Bula Boys Surf Tours Fiji on WhatsApp to check availability and plan your trip.
      </p>
      <a href={WHATSAPP_URL} class="btn btn--whatsapp final-cta__btn" target="_blank" rel="noopener noreferrer">
        <svg class="whatsapp-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Book on WhatsApp
      </a>
      <p class="final-cta__phone">WhatsApp {WHATSAPP_DISPLAY}</p>
    </div>
  </section>

  <footer class="footer">
    <div class="container footer__inner">
      <p class="footer__name">Bula Boys Surf Tours Fiji</p>
      <p class="footer__location">Nabila Village, Fiji · Cloudbreak</p>
      <div class="footer__social">
        {socialLinks.map((link) => (
          <a href={link.href} class="footer__social-link" target="_blank" rel="noopener noreferrer">
            {link.label}
          </a>
        ))}
      </div>
      <a href={WHATSAPP_URL} class="footer__link" target="_blank" rel="noopener noreferrer">
        WhatsApp {WHATSAPP_DISPLAY}
      </a>
    </div>
  </footer>
</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding-top: var(--header-height);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(11, 50, 70, 0.85) 0%,
      rgba(11, 80, 100, 0.45) 45%,
      rgba(26, 155, 184, 0.2) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding-block: 3rem 4rem;
    color: var(--white);
  }

  .hero__eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--seafoam);
    margin-bottom: 0.75rem;
  }

  .hero__title {
    font-size: clamp(2rem, 7vw, 3.25rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    max-width: 14ch;
  }

  .hero__subtitle {
    margin-top: 1rem;
    font-size: clamp(1rem, 3.5vw, 1.15rem);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.92);
    max-width: 34rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .hero__phone {
    display: inline-block;
    margin-top: 1.25rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--seafoam);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* About */
  .about__grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  .about__image-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    aspect-ratio: 4 / 3;
  }

  .about__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about__copy {
    margin-top: 1rem;
    color: var(--text-soft);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* Trips */
  .trips .section-lead {
    margin-bottom: 2rem;
  }

  .trips__grid {
    display: grid;
    gap: 1.25rem;
  }

  .trip-card {
    display: block;
    background: var(--white);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .trip-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(11, 110, 140, 0.18);
  }

  .trip-card__image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .trip-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .trip-card:hover .trip-card__image img {
    transform: scale(1.03);
  }

  .trip-card__body {
    padding: 1.25rem 1.25rem 1.5rem;
  }

  .trip-card__title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--ocean-deep);
  }

  .trip-card__copy {
    margin-top: 0.5rem;
    color: var(--text-soft);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .trip-card__link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ocean);
  }

  /* Why book */
  .why__list {
    list-style: none;
    margin: 1.75rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .why__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: linear-gradient(135deg, #f0faf7 0%, var(--sand) 100%);
    border-radius: var(--radius-sm);
    font-weight: 500;
    color: var(--text);
  }

  .why__check {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--turquoise);
    color: var(--white);
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 700;
  }

  /* Gallery */
  .gallery .section-lead {
    margin-bottom: 2rem;
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-flow: dense;
    gap: 0.75rem;
  }

  .gallery__item {
    margin: 0;
    border-radius: var(--radius-sm);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .gallery__item--large {
    grid-column: span 2;
    aspect-ratio: 16 / 10;
  }

  .gallery__item--small {
    aspect-ratio: 1;
  }

  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* FAQ */
  .faq__list {
    margin-top: 1.75rem;
    display: grid;
    gap: 0.75rem;
  }

  .faq__item {
    background: var(--white);
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(11, 110, 140, 0.06);
  }

  .faq__question {
    padding: 1.125rem 1.25rem;
    font-weight: 600;
    color: var(--ocean-deep);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::after {
    content: '+';
    font-size: 1.25rem;
    color: var(--ocean);
    font-weight: 400;
    flex-shrink: 0;
  }

  .faq__item[open] .faq__question::after {
    content: '−';
  }

  .faq__answer {
    padding: 0 1.25rem 1.125rem;
    color: var(--text-soft);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  /* Final CTA */
  .final-cta {
    position: relative;
    padding-block: 5rem;
    text-align: center;
    color: var(--white);
  }

  .final-cta__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .final-cta__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .final-cta__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(11, 110, 140, 0.82) 0%,
      rgba(232, 122, 93, 0.55) 100%
    );
  }

  .final-cta__content {
    position: relative;
    z-index: 1;
  }

  .final-cta__title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
  }

  .final-cta__copy {
    margin-top: 1rem;
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.92);
    max-width: 28rem;
    margin-inline: auto;
    line-height: 1.6;
  }

  .final-cta__btn {
    margin-top: 1.75rem;
    font-size: 1rem;
    padding: 1rem 1.75rem;
  }

  .final-cta__phone {
    margin-top: 1rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--seafoam);
  }

  /* Footer */
  .footer {
    background: var(--ocean-deep);
    color: rgba(255, 255, 255, 0.85);
    padding-block: 2rem;
    text-align: center;
  }

  .footer__name {
    font-weight: 700;
    font-size: 1rem;
    color: var(--white);
  }

  .footer__location {
    margin-top: 0.35rem;
    font-size: 0.9rem;
  }

  .footer__social {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .footer__social-link {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--seafoam);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer__link {
    display: inline-block;
    margin-top: 0.75rem;
    font-weight: 600;
    color: var(--seafoam);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Responsive */
  @media (min-width: 600px) {
    .why__list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .about__grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .trips__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .gallery__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .gallery__item--large {
      grid-column: span 2;
      grid-row: span 2;
      aspect-ratio: auto;
    }
  }

  @media (min-width: 1024px) {
    .section {
      padding-block: 5rem;
    }

    .hero__content {
      padding-block: 4rem 5rem;
    }
  }
</style>
