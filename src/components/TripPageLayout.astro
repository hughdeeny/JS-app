---
import Layout from '../layouts/Layout.astro';
import type { TripPage } from '../data/site';
import { WHATSAPP_DISPLAY, whatsappUrl, tripPages } from '../data/site';

interface Props {
  trip: TripPage;
}

const { trip } = Astro.props;
const bookUrl = whatsappUrl(trip.whatsappMessage);
const otherTrips = tripPages.filter((t) => t.slug !== trip.slug);
---

<Layout
  title={`${trip.title} | Bula Boys Surf Tours Fiji`}
  description={`${trip.tagline} Book with Bula Boys Surf Tours Fiji from Nabila Village. WhatsApp ${WHATSAPP_DISPLAY}.`}
>
  <section class="trip-hero">
    <div class="trip-hero__bg">
      <img src={trip.hero} alt={trip.heroAlt} />
      <div class="trip-hero__overlay"></div>
    </div>
    <div class="trip-hero__content container">
      <a href="/#trips" class="trip-hero__back">← All Trips</a>
      <h1 class="trip-hero__title">{trip.title}</h1>
      <p class="trip-hero__tagline">{trip.tagline}</p>
      <a href={bookUrl} class="btn btn--whatsapp" target="_blank" rel="noopener noreferrer">
        <svg class="whatsapp-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Book on WhatsApp
      </a>
    </div>
  </section>

  <section class="section trip-intro">
    <div class="container trip-intro__grid">
      <div>
        <h2 class="section-title">About This Trip</h2>
        <p class="trip-intro__copy">{trip.intro}</p>
      </div>
      <ul class="trip-highlights">
        {trip.highlights.map((point) => (
          <li class="trip-highlights__item">
            <span class="trip-highlights__check" aria-hidden="true">✓</span>
            {point}
          </li>
        ))}
      </ul>
    </div>
  </section>

  {trip.spots && (
    <section class="section section--sand trip-spots">
      <div class="container">
        <h2 class="section-title">Where We Go</h2>
        <div class="trip-spots__grid">
          {trip.spots.map((spot) => (
            <article class="trip-spot">
              <h3 class="trip-spot__name">{spot.name}</h3>
              <p class="trip-spot__copy">{spot.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section trip-gallery">
    <div class="container">
      <h2 class="section-title">Photos</h2>
      <div class="trip-gallery__grid">
        {trip.gallery.map((item) => (
          <figure class={`trip-gallery__item trip-gallery__item--${item.size ?? 'medium'}`}>
            <img src={item.src} alt={item.alt} loading="lazy" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--seafoam trip-others">
    <div class="container">
      <h2 class="section-title">Other Trips</h2>
      <div class="trip-others__grid">
        {otherTrips.map((other) => (
          <a href={`/trips/${other.slug}`} class="trip-other">
            <div class="trip-other__image">
              <img src={other.hero} alt={other.heroAlt} loading="lazy" />
            </div>
            <div class="trip-other__body">
              <h3 class="trip-other__title">{other.nav}</h3>
              <p class="trip-other__tagline">{other.tagline}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="trip-cta">
    <div class="container trip-cta__inner">
      <h2 class="trip-cta__title">Ready to Book?</h2>
      <p class="trip-cta__copy">Message Bula Boys on WhatsApp to check availability and plan your {trip.nav.toLowerCase()} trip.</p>
      <a href={bookUrl} class="btn btn--whatsapp trip-cta__btn" target="_blank" rel="noopener noreferrer">
        <svg class="whatsapp-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Book on WhatsApp
      </a>
      <p class="trip-cta__phone">WhatsApp {WHATSAPP_DISPLAY}</p>
    </div>
  </section>
</Layout>

<style>
  .trip-hero {
    position: relative;
    min-height: 55vh;
    display: flex;
    align-items: flex-end;
    padding-top: var(--header-height);
  }

  .trip-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .trip-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .trip-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(11, 50, 70, 0.88) 0%,
      rgba(11, 80, 100, 0.4) 50%,
      rgba(26, 155, 184, 0.15) 100%
    );
  }

  .trip-hero__content {
    position: relative;
    z-index: 1;
    padding-block: 2.5rem 3rem;
    color: var(--white);
  }

  .trip-hero__back {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--seafoam);
    margin-bottom: 1rem;
  }

  .trip-hero__back:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .trip-hero__title {
    font-size: clamp(1.75rem, 6vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    max-width: 16ch;
  }

  .trip-hero__tagline {
    margin-top: 0.75rem;
    font-size: clamp(1rem, 3vw, 1.15rem);
    color: rgba(255, 255, 255, 0.92);
    max-width: 32rem;
    line-height: 1.55;
  }

  .trip-hero__content .btn {
    margin-top: 1.5rem;
  }

  .trip-intro__grid {
    display: grid;
    gap: 2rem;
  }

  .trip-intro__copy {
    margin-top: 1rem;
    color: var(--text-soft);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 38rem;
  }

  .trip-highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .trip-highlights__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: linear-gradient(135deg, #f0faf7 0%, var(--sand) 100%);
    border-radius: var(--radius-sm);
    font-weight: 500;
    color: var(--text);
  }

  .trip-highlights__check {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--turquoise);
    color: var(--white);
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .trip-spots__grid {
    display: grid;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .trip-spot {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
    border-left: 4px solid var(--ocean);
  }

  .trip-spot__name {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--ocean-deep);
  }

  .trip-spot__copy {
    margin-top: 0.5rem;
    color: var(--text-soft);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .trip-gallery__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-flow: dense;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .trip-gallery__item {
    margin: 0;
    border-radius: var(--radius-sm);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .trip-gallery__item--large {
    grid-column: span 2;
    aspect-ratio: 16 / 10;
  }

  .trip-gallery__item--small {
    aspect-ratio: 1;
  }

  .trip-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .trip-others__grid {
    display: grid;
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  .trip-other {
    display: block;
    background: var(--white);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.15s ease;
  }

  .trip-other:hover {
    transform: translateY(-2px);
  }

  .trip-other__image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .trip-other__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .trip-other__body {
    padding: 1.25rem;
  }

  .trip-other__title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ocean-deep);
  }

  .trip-other__tagline {
    margin-top: 0.35rem;
    font-size: 0.9rem;
    color: var(--text-soft);
    line-height: 1.5;
  }

  .trip-cta {
    background: linear-gradient(135deg, var(--ocean-deep) 0%, var(--ocean) 100%);
    color: var(--white);
    padding-block: 4rem;
    text-align: center;
  }

  .trip-cta__title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
  }

  .trip-cta__copy {
    margin-top: 0.75rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 28rem;
    margin-inline: auto;
    line-height: 1.6;
  }

  .trip-cta__btn {
    margin-top: 1.5rem;
  }

  .trip-cta__phone {
    margin-top: 1rem;
    font-weight: 600;
    color: var(--seafoam);
    font-size: 0.95rem;
  }

  @media (min-width: 768px) {
    .trip-hero {
      min-height: 60vh;
    }

    .trip-intro__grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 3rem;
      align-items: start;
    }

    .trip-spots__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .trip-gallery__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .trip-gallery__item--large {
      grid-column: span 2;
      grid-row: span 2;
      aspect-ratio: auto;
    }

    .trip-others__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
